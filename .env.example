VAULT_ADDR=https://vault.mydomain.com
VAULT_TOKEN=XXXXXXXXXXXXXXXXXXX
OPENBAO_ADDR=https://openbao.mydomain.com
OPENBAO_TOKEN=XXXXXXXXXXXXXXXXXXX
DRY_RUN=false
SKIP_TLS_VERIFY=false
SKIP_MOUNTS=sys,identity,cubbyhole
# Comma-separated list of policy names to skip
SKIP_POLICIES=
# Comma-separated list of auth method paths to skip
SKIP_AUTH_METHODS=
CONCURRENCY=5
